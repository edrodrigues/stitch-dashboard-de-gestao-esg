rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite acesso permanente (sem expiração) para qualquer usuário autenticado.
    // Garante que apenas usuários logados possam ler ou escrever no banco de dados.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
